<UserControl x:Class="Aplicacio.Views.FormulariPersonatge"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aplicacio.Views"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="900">

    <UserControl.Resources>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#121212"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Style.Triggers>
                <Trigger Property="IsReadOnly" Value="True">
                    <Setter Property="Background" Value="#1A1A1A"/>
                    <Setter Property="Foreground" Value="#888"/>
                    <Setter Property="BorderBrush" Value="#333"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="BotoAccio" TargetType="Button">
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#121212" Padding="20">
            <TextBlock x:Name="txtTitol" Text="NOU PERSONATGE" FontSize="24" FontWeight="Bold" Foreground="#F5F5F5" Margin="0"/>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="30,20,30,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Codi (Auto-generat)"/>
                    <TextBox x:Name="txtId" Style="{StaticResource InputStyle}" IsReadOnly="True" Text="-" />

                    <TextBlock Text="Nom *"/>
                    <TextBox x:Name="txtNom" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Descripció"/>
                    <TextBox x:Name="txtDescripcio" Style="{StaticResource InputStyle}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" />

                    <CheckBox x:Name="chkJugable" Content="És un personatge jugable?" Foreground="#F5F5F5" FontSize="16" Margin="0,10,0,0">
                        <CheckBox.LayoutTransform>
                            <ScaleTransform ScaleX="1.2" ScaleY="1.2" />
                        </CheckBox.LayoutTransform>
                    </CheckBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Vida *"/>
                    <TextBox x:Name="txtVida" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Atac *"/>
                    <TextBox x:Name="txtAtac" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Defensa *"/>
                    <TextBox x:Name="txtDefensa" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Velocitat *"/>
                    <TextBox x:Name="txtVelocitat" Style="{StaticResource InputStyle}" />

                    <TextBlock Text="Experiència (Base/Aportada) *"/>
                    <TextBox x:Name="txtExperiencia" Style="{StaticResource InputStyle}" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#121212" Padding="20" Margin="0,20,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Tornar" Style="{StaticResource BotoAccio}" Background="#333333" Margin="0,0,15,0" Click="BtnTornar_Click"/>
                <Button x:Name="btnEditar" Content="Modificar" Style="{StaticResource BotoAccio}" Background="#7A1121" Margin="0,0,15,0" Click="BtnCanviarAEdicio_Click"/>
                <Button x:Name="btnGuardar" Content="Guardar Dades" Style="{StaticResource BotoAccio}" Background="#A3162D" Click="BtnGuardar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>