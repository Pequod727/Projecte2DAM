<UserControl x:Class="Aplicacio.Views.FormulariAccio"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Aplicacio.Views"
             xmlns:uc="clr-namespace:Aplicacio.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="SectionCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="25"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="BorderBrush" Value="#2A2A2A"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="BlackCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444"/>
            <Setter Property="Height" Value="35"/>
            <Style.Resources>
                <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="Black" />
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#A3162D" />
            </Style.Resources>
        </Style>
    </UserControl.Resources>

    <Grid Background="#0D0D0D">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141414" BorderBrush="#A3162D" BorderThickness="0,0,0,2">
            <StackPanel Orientation="Horizontal" Margin="40,0">
                <TextBlock Text="CONFIGURACIÓ D'ACCIÓ I EFECTES" VerticalAlignment="Center" Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text=" | ID:" VerticalAlignment="Center" Foreground="#444" Margin="15,0,5,0"/>
                <TextBlock x:Name="txtIdAccio" Text="NEW" VerticalAlignment="Center" Foreground="#A3162D" FontWeight="Bold" FontSize="18"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="TIPUS D'ENTITAT" Foreground="#A3162D" FontWeight="Bold" Margin="0,0,0,15"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton x:Name="rbHabilitat" Content="Habilitat" Foreground="White" IsChecked="True" Margin="0,0,20,0"/>
                                <RadioButton x:Name="rbItem" Content="Item Consumible" Foreground="White"/>
                            </StackPanel>
                            <TextBlock Text="NOM DE L'ACCIÓ *" Foreground="#777" FontSize="11" Margin="0,10,0,5"/>
                            <TextBox x:Name="txtNomAccio" Background="Black" Foreground="White" BorderBrush="#333" Padding="8"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="EFECTES (1-20)" Foreground="#A3162D" FontWeight="Bold" Margin="0,0,0,15"/>
                            <ListBox x:Name="lbEfectes" Background="#050505" BorderBrush="#333" Height="300" 
                                     Foreground="White" MouseDoubleClick="LbEfectes_MouseDoubleClick">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Nom}" VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✕" Click="BtnEliminarEfecte_Click" 
                                                    Background="Transparent" Foreground="#A3162D" BorderThickness="0" Margin="10,0,0,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button x:Name="btnAfegirEfecte" Content="+ AFEGIR NOU EFECTE" Margin="0,15,0,0" 
                                    Height="35" Background="#2A2A2A" Foreground="White" BorderThickness="0" Click="BtnAfegirEfecte_Click"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" x:Name="panelConfigEfecte" IsEnabled="False">
                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="DETALLS DE L'EFECTE" Foreground="#A3162D" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="NOM DE L'EFECTE *" Foreground="#777" FontSize="11" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtNomEfecte" Background="Black" Foreground="White" BorderBrush="#333" Padding="8" Margin="0,0,0,15"/>

                            <TextBlock Text="DESCRIPCIÓ" Foreground="#777" FontSize="11" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtDescEfecte" Height="80" Background="Black" Foreground="White" BorderBrush="#333" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

                            <TextBlock Text="OBJECTIU *" Foreground="#777" FontSize="11" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbObjectiu" Style="{StaticResource BlackCombo}" Margin="0,0,0,15"/>

                            <uc:Slider x:Name="sldProbabilitat" Titol="PROBABILITAT D'IMPACTE (%)" Minim="1" Maxim="100"/>

                            <TextBlock Text="TIPUS D'EFECTE" Foreground="#777" FontSize="11" Margin="0,15,0,5"/>
                            <StackPanel Orientation="Horizontal">
                                <RadioButton x:Name="rbModEstadistica" Content="Estadística" Foreground="White" Margin="0,0,20,0" Checked="TipusEfecte_Changed"/>
                                <RadioButton x:Name="rbCanviEstat" Content="Estat" Foreground="White" Checked="TipusEfecte_Changed"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" x:Name="panelDetallsEspecífics" IsEnabled="False">

                    <Border Style="{StaticResource SectionCard}" x:Name="cardEstadistica" Visibility="Visible">
                        <StackPanel>
                            <TextBlock Text="MODIFICADOR D'ESTADÍSTICA" Foreground="#A3162D" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="ESTADÍSTICA A MODIFICAR" Foreground="#777" FontSize="11" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbEstadistica" Style="{StaticResource BlackCombo}" Margin="0,0,0,15"/>

                            <uc:Slider x:Name="sldQuantitat" Titol="QUANTITAT (MODIFICADOR)" Minim="-255" Maxim="255"/>

                            <TextBlock Margin="0,10,0,0" Text="* Valors negatius per a mal, positius per a cura/buff." Foreground="#444" FontSize="10" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}" x:Name="cardEstat" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="CANVI D'ESTAT" Foreground="#A3162D" FontWeight="Bold" Margin="0,0,0,15"/>

                            <TextBlock Text="ESTAT" Foreground="#777" FontSize="11" Margin="0,0,0,5"/>
                            <ComboBox x:Name="cbEstats" Style="{StaticResource BlackCombo}" Margin="0,0,0,15"/>

                            <TextBlock Text="ACCIÓ SOBRE L'ESTAT" Foreground="#777" FontSize="11" Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <RadioButton x:Name="rbAfegirEstat" Content="Afegir" Foreground="White" Margin="0,0,20,0" IsChecked="True"/>
                                <RadioButton x:Name="rbTreureEstat" Content="Treure" Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCard}">
                        <StackPanel>
                            <TextBlock Text="DURACIÓ DE L'EFECTE" Foreground="#A3162D" FontWeight="Bold" Margin="0,0,0,15"/>
                            <uc:Slider x:Name="sldDuracio" Titol="TORNS DE DURACIÓ" Minim="0" Maxim="10"/>
                            <TextBlock Text="* Si és 0, l'efecte és instantani." Foreground="#444" FontSize="10" FontStyle="Italic" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#141414" Padding="40,0" BorderBrush="#222" BorderThickness="0,1,0,0">
            <DockPanel LastChildFill="False">
                <Button Content="TORNAR" Click="BtnTornar_Click" Background="Transparent" Foreground="#666" BorderThickness="0" Cursor="Hand" FontWeight="Bold"/>
                <Button x:Name="btnGuardarAccio" Content="GUARDAR CONFIGURACIÓ" DockPanel.Dock="Right" Click="BtnGuardar_Click" Width="250" Height="40" Background="#A3162D" Foreground="White" FontWeight="Bold">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
