<Page x:Class="Aplicacio.Views.Menu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Aplicacio.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="Menu">

    <Page.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="Background" Value="#7A1121"/>
            <Setter Property="Margin" Value="0,12"/>
            <Setter Property="Padding" Value="25,15"/>
            <Setter Property="MinHeight" Value="60"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A3162D"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#121212">
        <Border Background="#1E1E1E" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40,30" CornerRadius="10" MinWidth="450">
            <StackPanel>
                <Image Source="/Resources/Images/mcIcona.png" Width="250" Height="120"/>

                <Button Tag="Personatges" Style="{StaticResource MenuButtonStyle}" Click="BtnOpcio_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/editPersonatge.png" Width="36" Height="36" Margin="0,0,15,0"/>
                        <TextBlock Text="Gestió de Personatges" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Tag="Nivells" Style="{StaticResource MenuButtonStyle}" Click="BtnOpcio_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/editNivell.png" Width="32" Height="32" Margin="0,0,15,0"/>
                        <TextBlock Text="Gestió de Nivells" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Tag="Habilitats" Style="{StaticResource MenuButtonStyle}" Click="BtnOpcio_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/editHabilitat.png" Width="38" Height="38" Margin="0,0,15,0"/>
                        <TextBlock Text="Gestió d'Ítems i Habilitats" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Style="{StaticResource MenuButtonStyle}" Background="#333333" Margin="0,40,0,0" Click="BtnSortir_Click">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/Resources/Images/exit.png" Width="28" Height="28" Margin="0,0,15,0"/>
                        <TextBlock Text="Sortir" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Page>