<Page x:Class="Aplicacio.Views.SplashScreen"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Aplicacio.Views"
      mc:Ignorable="d" 
      d:DesignHeight="600" d:DesignWidth="900"
      Title="SplashScreen">

    <Grid Background="#121212">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Gestor de Moment Crític" FontSize="48" FontWeight="Bold" Foreground="#F5F5F5" Margin="0,0,0,20" HorizontalAlignment="Center" />

            <ProgressBar IsIndeterminate="True" Width="300" Height="10" Margin="0,10" Foreground="#A3162D" Background="#2A2A2A" BorderThickness="0" />

            <TextBlock Text="Iniciant el sistema..." FontSize="16" Foreground="#B0B0B0" HorizontalAlignment="Center" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Page>