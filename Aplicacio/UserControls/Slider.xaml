<UserControl x:Class="Aplicacio.UserControls.Slider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="800">

    <Border Padding="20,10" Background="Transparent" HorizontalAlignment="Stretch">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="lblTitol" Text="ESTADÍSTICA" Foreground="#999" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>

            <Slider Grid.Column="1" x:Name="sldValor" Minimum="1" Maximum="255" 
                    IsSnapToTickEnabled="True" TickFrequency="1" 
                    SmallChange="1" LargeChange="10" IsMoveToPointEnabled="True"
                    VerticalAlignment="Center" Cursor="Hand"
                    Margin="15,0"/>

            <Border Grid.Column="2" Background="#252525" CornerRadius="5" Padding="5,2" HorizontalAlignment="Right" MinWidth="60">
                <TextBox x:Name="txtValor" 
                         Text="{Binding ElementName=sldValor, Path=Value, UpdateSourceTrigger=PropertyChanged}"
                         Foreground="#A3162D" 
                         Background="Transparent" 
                         BorderThickness="0"
                         HorizontalContentAlignment="Center" 
                         VerticalContentAlignment="Center" 
                         FontWeight="Bold"
                         FontSize="14"
                         LostFocus="TxtValor_LostFocus"
                         KeyDown="TxtValor_KeyDown"/>
            </Border>
        </Grid>
    </Border>
    
</UserControl>