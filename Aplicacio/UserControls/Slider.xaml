<UserControl x:Class="Aplicacio.UserControls.Slider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" d:DesignWidth="800">

    <Border Padding="20,10" Background="Transparent" HorizontalAlignment="Stretch">
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="70"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="lblTitol" Text="ESTADÍSTICA" Foreground="#999" VerticalAlignment="Center" FontSize="12" FontWeight="Bold"/>

            <Slider Grid.Column="1" x:Name="sldValor" Minimum="1" Maximum="255" 
                    IsSnapToTickEnabled="True" TickFrequency="1" 
                    SmallChange="1" LargeChange="10" IsMoveToPointEnabled="True"
                    VerticalAlignment="Center" Cursor="Hand"
                    Margin="15,0"/>

            <Border Grid.Column="2" Background="#252525" CornerRadius="5" Padding="8,4" HorizontalAlignment="Right" MinWidth="50">
                <TextBlock Text="{Binding ElementName=sldValor, Path=Value}" 
                           Foreground="#A3162D" FontWeight="Black" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Border>
</UserControl>